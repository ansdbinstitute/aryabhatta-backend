# =============================================================================
# ANSDB Backend - Environment Variables Template
# =============================================================================
# Copy this file to .env and update the values for your environment
# IMPORTANT: Never commit .env file to version control!
# =============================================================================

HOST=0.0.0.0
PORT=1337

# =============================================================================
# SECURITY KEYS - IMPORTANT: Generate new values for production!
# =============================================================================
# Run these commands to generate new secure values:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
#
# For APP_KEYS, generate 4 comma-separated values:
#   node -e "console.log([1,2,3,4].map(() => require('crypto').randomBytes(16).toString('hex')).join(','))"
# =============================================================================

APP_KEYS="toBeModified1,toBeModified2,toBeModified3,toBeModified4"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Default: SQLite (recommended for development/small deployments)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For PostgreSQL (recommended for production):
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=ansdb
# DATABASE_USERNAME=ansdb
# DATABASE_PASSWORD=your_secure_password
# DATABASE_SSL=false

# =============================================================================
# URL CONFIGURATION (Update for production)
# =============================================================================
# APP_URL=https://api.your-domain.com
# FRONTEND_URL=https://www.your-domain.com

# =============================================================================
# ADMIN RESET TOKEN EXPIRATION (milliseconds)
# =============================================================================
ADMIN_RESET_TOKEN_EXPIRATION=604800000
