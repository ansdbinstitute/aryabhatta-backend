{
  "kind": "collectionType",
  "collectionName": "results",
  "info": {
    "singularName": "result",
    "pluralName": "results",
    "displayName": "Result"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "marksObtained": {
      "type": "decimal",
      "required": true
    },
    "grade": {
      "type": "string"
    },
    "remarks": {
      "type": "text"
    },
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student.student"
    },
    "exam": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::exam.exam"
    },
    "marksheet": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    }
  }
}