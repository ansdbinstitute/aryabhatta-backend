{
  "kind": "collectionType",
  "collectionName": "exam_approvals",
  "info": {
    "singularName": "exam-approval",
    "pluralName": "exam-approvals",
    "displayName": "Exam Approval"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student.student",
      "required": true
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "required": true
    },
    "batch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::batch.batch"
    },
    "exam": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::exam.exam",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending",
      "required": true
    },
    "remarks": {
      "type": "text"
    },
    "approvedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::staff.staff"
    }
  }
}
