{
  "kind": "singleType",
  "collectionName": "institute_settings",
  "info": {
    "singularName": "institute-setting",
    "pluralName": "institute-settings",
    "displayName": "Institute Settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
  "attributes": {
    "instituteName": {
      "type": "string",
      "default": "Aryabhatta National Skill Development Board"
    },
    "instituteCode": {
      "type": "string",
      "default": "ANSDB"
    },
    "contactEmail": {
      "type": "email"
    },
    "contactPhone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "currentAcademicYear": {
      "type": "string",
      "default": "2026-27"
    },
    "receiptPrefix": {
      "type": "string",
      "default": "REC-"
    },
    "studentUidFormat": {
      "type": "string",
      "default": "{INST}-{YEAR}-{COURSE}-{SEQ}"
    }
  }
}