{
  "kind": "collectionType",
  "collectionName": "branches",
  "info": {
    "singularName": "branch",
    "pluralName": "branches",
    "displayName": "Branch",
    "description": "Educational branch locations for institutional scaling"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "address": {
      "type": "text",
      "required": true
    },
    "staffs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::staff.staff",
      "mappedBy": "branch"
    },
    "users": {
        "type": "relation",
        "relation": "oneToMany",
        "target": "plugin::users-permissions.user",
        "mappedBy": "branch"
    }
  }
}
